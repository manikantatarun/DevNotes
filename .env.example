# DevNotes – environment variables
# Copy this to .env.local and fill in your values.
# .env.local is git-ignored.

# ── GitHub OAuth App ───────────────────────────────────────────────────────────
# Create one at https://github.com/settings/developers → OAuth Apps → New
# Callback URL:  https://<your-pages-domain>/DevNotes/
VITE_GITHUB_CLIENT_ID=Ov23liGfeE9zIi8ekes4

# ── Cloudflare Worker (OAuth token exchange) ───────────────────────────────────
# Deploy cloudflare-worker/worker.js and paste the worker URL here
VITE_OAUTH_WORKER_URL=https://devnotes.manikanta-tarun.workers.dev

# ── Data repository ────────────────────────────────────────────────────────────
# The repo that stores notes.json (must be public for read-only viewers)
VITE_DATA_REPO_OWNER=manikantatarun
VITE_DATA_REPO_NAME=devnotes-data
VITE_DATA_REPO_BRANCH=main

# ── App base path (matches vite.config.ts base) ──────────────────────────────
# Used to build the OAuth redirect URI
VITE_APP_BASE_URL=https://manikantatarun.github.io/DevNotes
